# Authentication
API_KEY=

# Hugging Face token (required for diarization model download/use)
HF_TOKEN=

# Parakeet config
PARAKEET__MODEL_NAME=nvidia/parakeet-tdt-0.6b-v2
PARAKEET__DEVICE=cpu
PARAKEET__PRELOAD_MODEL=false
PARAKEET__LOCAL_FILES_ONLY=false

# Diarization config
DIARIZATION__MODEL_NAME=pyannote/speaker-diarization-community-1
DIARIZATION__DEVICE=cpu
DIARIZATION__PRELOAD_MODEL=false

# API runtime
MAX_CONCURRENT_TRANSCRIPTIONS=2
DEBUG_LOG_TRANSCRIPTION_PAYLOAD=false
UVICORN_HOST=0.0.0.0
UVICORN_PORT=7317
HOST_PORT_CPU=7474
HOST_PORT_CUDA=7373

# CUDA profile overrides (compose.yaml)
# Keep ASR on GPU by default; diarization defaults to CPU to reduce VRAM pressure.
PARAKEET__DEVICE_CUDA=cuda
DIARIZATION__DEVICE_CUDA=cpu
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
