# Authentication
API_KEY=

# Hugging Face token (required for diarization model download/use)
HF_TOKEN=

# Parakeet config
PARAKEET__MODEL_NAME=nvidia/parakeet-tdt-0.6b-v2
PARAKEET__PRELOAD_MODEL=false
PARAKEET__LOCAL_FILES_ONLY=false
PARAKEET__CUDA_HALF_PRECISION=true
PARAKEET__CUDA_ADAPTIVE_CHUNKING=true
PARAKEET__CUDA_CHUNK_SECONDS_OVERRIDE=
PARAKEET__CUDA_CHUNK_MIN_SECONDS=30
PARAKEET__CUDA_CHUNK_MAX_SECONDS=600
PARAKEET__CUDA_CHUNK_OVERLAP_SECONDS=0.0

# Diarization config
DIARIZATION__MODEL_NAME=pyannote/speaker-diarization-community-1
DIARIZATION__PRELOAD_MODEL=false

# API runtime
MAX_CONCURRENT_TRANSCRIPTIONS=1
DEBUG_LOG_TRANSCRIPTION_PAYLOAD=false
MODEL_IDLE_EVICT_MINUTES=10
UVICORN_HOST=0.0.0.0
UVICORN_PORT=7474
HOST_PORT=7474

# CUDA profile overrides (compose.yaml and compose.cuda-legacy.yaml)
PARAKEET__DEVICE_CUDA=cuda
DIARIZATION__DEVICE_CUDA=cuda
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
